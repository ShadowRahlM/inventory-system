# Django
SECRET_KEY=generate-a-random-secret-key-here
DEBUG=false
ALLOWED_HOSTS=localhost,yourdomain.com

# PostgreSQL
DB_NAME=inventory_db
DB_USER=postgres
DB_PASSWORD=postgres

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://yourdomain.com

# Port mapping
PORT=8080

# Sync peers (multi-laptop)
SYNC_PEERS=
